{
  "$schema": "https://turbo.build/schema.json",
  "envMode": "loose",
  "ui": "stream",
  "tasks": {
    "build": {
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {
      "dependsOn": ["^type-check"]
    }
  }
}
