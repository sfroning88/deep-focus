///////////////////////////////////////////////////////////////////////////////////////////
//                                    NIC PROPERTY                                       //
///////////////////////////////////////////////////////////////////////////////////////////

model Property {
    id                      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    name                    String @unique
    address                 String
    city                    String
    state                   NICState
    zip                     String
    yearBuilt               Int @map("year_built")
    yearRenovated           Int? @map("year_renovated")
    unitSize                Decimal @map("unit_size") @db.Decimal(14,2)
    cottageUnits            Int @map("cottage_units") @default(0)
    independentUnits        Int @map("independent_units") @default(0)
    assistedUnits           Int @map("assisted_units") @default(0)
    memoryUnits             Int @map("memory_units") @default(0)
    totalUnits              Int @map("total_units") @default(0)
    totalBeds               Int @map("total_beds") @default(0)

    msaId                   String @map("msa_id") @db.Uuid
    msa                     NICMSA @relation(fields: [msaId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    snapshots               PropertySnapshot[]
    predictions             Prediction[]

    @@index([msaId], map: "idx_property_by_msa")
    @@map("property")
    @@schema("property")
}

model PropertySnapshot {
    reportedAt              DateTime @map("reported_at") @db.Date
    occupancy               Decimal @default(0) @db.Decimal(5,2)
    totalRevenues           Decimal @map("total_revenues") @default(0) @db.Decimal(14,2)
    repairsMaintenance      Decimal @map("repairs_maintenance") @default(0) @db.Decimal(14,2)
    payroll                 Decimal @default(0) @db.Decimal(14,2)
    utilities               Decimal @default(0) @db.Decimal(14,2)
    contractServices        Decimal @map("contract_services") @default(0) @db.Decimal(14,2)
    rawFood                 Decimal @map("raw_food") @default(0) @db.Decimal(14,2)
    culinarySupplies        Decimal @map("culinary_supplies") @default(0) @db.Decimal(14,2)
    administrative          Decimal @default(0) @db.Decimal(14,2)
    marketingPromotions     Decimal @map("marketing_promotions") @default(0) @db.Decimal(14,2)
    activities              Decimal @default(0) @db.Decimal(14,2)
    otherExpenses           Decimal @map("other_expenses") @default(0) @db.Decimal(14,2)
    controllableExpenses    Decimal @map("controllable_expenses") @default(0) @db.Decimal(14,2)
    managementFee           Decimal @map("management_fee") @default(0) @db.Decimal(14,2)
    realEstateTaxes         Decimal @map("real_estate_taxes") @default(0) @db.Decimal(14,2)
    insurance               Decimal @default(0) @db.Decimal(14,2)
    nonControllableExpenses Decimal @map("non_controllable_expenses") @default(0) @db.Decimal(14,2)
    totalExpenses           Decimal @map("total_expenses") @default(0) @db.Decimal(14,2)
    operatingMargin         Decimal @map("operating_margin") @default(0) @db.Decimal(5,2)
    controllablePRD         Decimal @map("controllable_prd") @default(0) @db.Decimal(14,2)

    propertyId              String @map("property_id") @db.Uuid
    property                Property @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
    
    @@id([propertyId, reportedAt])
    @@map("property_snapshot")
    @@schema("property")
}

///////////////////////////////////////////////////////////////////////////////////////////
