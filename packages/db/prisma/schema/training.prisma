///////////////////////////////////////////////////////////////////////////////////////////
//                                    TRAINING RUN                                       //
///////////////////////////////////////////////////////////////////////////////////////////

enum TrainingType {
    linear
    ridge
    forest
    gbm
    xgboost
    lasso
    svr
    elasticnet

    @@map("training_type")
    @@schema("ai")
}

enum TrainingStatus {
    pending
    executing
    completed
    failed
    cancelled

    @@map("training_status")
    @@schema("ai")
}

enum TrainingFunction {
    train
    validate
    test

    @@map("training_function")
    @@schema("ai")
}

model TrainingMSAEncoding {
    meanTarget              Decimal @map("mean_target") @db.Decimal(14,2)
    sampleCount             Int @map("sample_count")

    msaId                   String @map("msa_id") @db.Uuid
    msa                     NICMSA @relation(fields: [msaId], references: [id], onDelete: Restrict, onUpdate: Cascade)

    batchId                 String @map("batch_id") @db.Uuid
    batch                   TrainingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    @@id([batchId, msaId])
    @@index([batchId], map: "idx_msa_encoding_by_batch")
    @@map("training_msa_encoding")
    @@schema("ai")
}

model TrainingFeature {
    columns                 String[]
    target                  String
    schemaVersion           Int @map("schema_version") @default(1)

    batchId                 String @id @map("batch_id") @unique @db.Uuid
    batch                   TrainingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    @@map("training_feature")
    @@schema("ai")
}

model TrainingSplit {
    version                 Int @id
    trainRatio              Decimal @map("train_ratio") @db.Decimal(3,2)
    validateRatio           Decimal @map("validate_ratio") @db.Decimal(3,2)
    testRatio               Decimal @map("test_ratio") @db.Decimal(3,2)
    shuffledAt              DateTime @map("shuffled_at") @db.Timestamptz(6)

    createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    batches                 TrainingBatch[]

    @@map("training_split")
    @@schema("ai")
}

model TrainingBatch {
    id                      String @id @db.Uuid
    status                  TrainingStatus
    samples                 Int
    splitSeed               Int @map("split_seed")
    
    splitVersionId          Int? @map("split_version")
    splitVersion            TrainingSplit? @relation(fields: [splitVersionId], references: [version], onDelete: Restrict, onUpdate: Cascade)
    
    createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    feature                 TrainingFeature?
    models                  TrainingModel[]
    encodings               TrainingMSAEncoding[]

    @@index([createdAt(sort: Desc)], map: "idx_training_batch_by_recency")
    @@map("training_batch")
    @@schema("ai")
}

model TrainingModel {
    type                    TrainingType
    status                  TrainingStatus
    r2score                 Decimal @map("r2_score") @db.Decimal(6,4)
    trainScore              Decimal? @map("train_score") @db.Decimal(6,4)
    validateScore           Decimal? @map("validate_score") @db.Decimal(6,4)
    rmse                    Decimal @db.Decimal(14,2)
    winner                  Boolean @default(false)
    storagePath             String @map("storage_path")
    trainedAt               DateTime @map("trained_at") @db.Timestamptz(6)
    errorMessage            String? @map("error_message")

    batchId                 String @map("batch_id") @db.Uuid
    batch                   TrainingBatch @relation(fields: [batchId], references: [id], onDelete: Restrict, onUpdate: Cascade)

    createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

    predictions             Prediction[]

    @@id([type, batchId])
    @@index([batchId, winner])
    @@map("training_model")
    @@schema("ai")
}

